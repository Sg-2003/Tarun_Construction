{
  "name": "tarun-construction",
  "version": "1.0.0",
  "description": "Tarun Construction — MEAN Stack + Three.js Website",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\" --names \"SERVER,CLIENT\" --prefix-colors \"yellow,cyan\"",
    "server": "cd server && npm run dev",
    "client": "cd client && ng serve --open",
    "build": "cd client && ng build --configuration production",
    "install:all": "cd server && npm install && cd ../client && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "multer": "^2.0.0",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.13"
  }
}
